# GigaAM ASR — example configuration. Copy to `.env` and edit as needed.
# Full variable reference — in the README (the "Configuration" section).

# --- Model and device ---
# GigaAM model name (must be in ALLOWED_MODELS).
MODEL=v3_ctc
# Inference device: auto|cpu|mps|cuda. auto: cuda→mps→cpu.
DEVICE=auto

# --- Authentication ---
# Bearer key for OpenAI-compatible clients. Empty → auth disabled (set it in prod).
API_KEY=

# --- Weights and resources ---
# Weights cache directory. Default /data/models — for the container (a mounted volume,
# the host ./models must be owned by UID 1000). On the native dev Mac specify an accessible
# path, e.g. ./models or ~/.cache/gigaam. Passed to GigaAM's download_root.
MODELS_DIR=/data/models
# Dynamic int8 quantization (stage 07).
QUANTIZE_INT8=false
# Longform inference batch size.
BATCH_SIZE=4
# torch.set_num_threads (number of CPU-inference threads).
NUM_THREADS=4

# --- Upload limits ---
# Upload file size limit, MB.
MAX_UPLOAD_MB=2048
# Audio duration limit, seconds (10h). 0 = no limit.
MAX_AUDIO_SECONDS=36000
# Inference queue limit (queued + in progress). Beyond — HTTP 503.
MAX_QUEUE=8

# --- VAD / chunking (stage 03) ---
# Min. segment length, sec.
VAD_MIN_DURATION=15.0
# Target maximum segment length, sec.
VAD_MAX_DURATION=22.0
# Hard maximum, sec (beyond — force-cut).
VAD_STRICT_LIMIT=30.0
# New-chunk threshold, sec.
VAD_NEW_CHUNK_THRESHOLD=0.2
# Silero VAD: speech probability threshold (lower = more context per chunk; 0.2-0.3 best, do not go below 0.2).
VAD_THRESHOLD=0.25

# --- HTTP server ---
# uvicorn host.
HOST=0.0.0.0
# uvicorn port.
PORT=8000

# --- Logging ---
# Log level: DEBUG|INFO|WARNING|ERROR.
LOG_LEVEL=INFO
# true → compact JSON log format, otherwise human-readable.
LOG_JSON=false

# --- API ---
# Default response format: json|text|verbose_json|srt|vtt.
DEFAULT_RESPONSE_FORMAT=json
# Allowed values of the `model` field (CSV).
ALLOWED_MODELS=v3_ctc,v3_e2e_ctc,v3_rnnt,v3_e2e_rnnt
