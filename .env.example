# GigaAM ASR — пример конфигурации. Скопируйте в `.env` и измените при необходимости.
# Полное описание переменных — docs/specs/00-master.md §7.

# --- Модель и устройство ---
# Имя модели GigaAM (должно входить в ALLOWED_MODELS).
MODEL=v3_ctc
# Устройство инференса: auto|cpu|mps|cuda. auto: cuda→mps→cpu.
DEVICE=auto

# --- Аутентификация ---
# Bearer-ключ для OpenAI-совместимых клиентов. Пусто → auth выключен (в проде задайте).
API_KEY=

# --- Веса и ресурсы ---
# Каталог кэша весов (монтируемый volume). Передаётся в download_root GigaAM.
MODELS_DIR=/data/models
# Динамическая int8-квантизация (этап 07).
QUANTIZE_INT8=false
# Размер батча longform-инференса.
BATCH_SIZE=4
# torch.set_num_threads (число потоков CPU-инференса).
NUM_THREADS=4

# --- Лимиты загрузки ---
# Лимит размера загружаемого файла, МБ.
MAX_UPLOAD_MB=2048
# Лимит длительности аудио, секунды (10ч). 0 = без лимита.
MAX_AUDIO_SECONDS=36000
# Лимит очереди инференса (в очереди + в работе). Сверх — HTTP 503.
MAX_QUEUE=8

# --- VAD / чанкинг (этап 03) ---
# Мин. длина сегмента, сек.
VAD_MIN_DURATION=15.0
# Целевой максимум длины сегмента, сек.
VAD_MAX_DURATION=22.0
# Жёсткий максимум, сек (сверх — режем принудительно).
VAD_STRICT_LIMIT=30.0
# Порог нового чанка, сек.
VAD_NEW_CHUNK_THRESHOLD=0.2
# Silero VAD: порог вероятности речи.
VAD_THRESHOLD=0.5

# --- HTTP-сервер ---
# Хост uvicorn.
HOST=0.0.0.0
# Порт uvicorn.
PORT=8000

# --- Логирование ---
# Уровень логов: DEBUG|INFO|WARNING|ERROR.
LOG_LEVEL=INFO
# true → компактный JSON-формат логов, иначе человекочитаемый.
LOG_JSON=false

# --- API ---
# Формат ответа по умолчанию: json|text|verbose_json|srt|vtt.
DEFAULT_RESPONSE_FORMAT=json
# Допустимые значения поля `model` (CSV).
ALLOWED_MODELS=v3_ctc,v3_e2e_ctc,v3_rnnt,v3_e2e_rnnt
